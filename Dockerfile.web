# ── Stage 1: Build ───────────────────────────────────────────────────
FROM node:22-slim AS builder

WORKDIR /app
RUN corepack enable

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .

ENV NEXT_TELEMETRY_DISABLED=1
RUN pnpm build

# ── Stage 2: Runtime ─────────────────────────────────────────────────
FROM node:22-slim

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Copy standalone build (includes minimal node_modules with better-sqlite3)
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

# Default config (copied to data volume on first run if missing)
COPY config.json ./config.json.default

RUN mkdir -p data

ENV DATABASE_PATH=/app/data/operator.db
ENV CONFIG_PATH=/app/data/config.json
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

EXPOSE 3000

CMD ["sh", "-c", "cp -n config.json.default /app/data/config.json 2>/dev/null || true; exec node server.js"]
